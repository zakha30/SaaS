<?xml version="1.0" encoding="utf-8" ?>
<!-- NLog: production-friendly rolling files + console. Tune rules/min levels here without redeploying code (autoReload=true). -->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/internal-nlog.txt">

  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
  </extensions>

  <!-- Default log dir next to the app; ensure the process user can write (production/Linux containers). -->
  <variable name="logDirectory" value="${basedir}/logs" />

  <targets>
    <!-- All application + framework logs (rolling daily, retained). -->
    <target xsi:type="File"
            name="allFile"
            fileName="${logDirectory}/app-${shortdate}.log"
            archiveFileName="${logDirectory}/archive/app-{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyy-MM-dd"
            maxArchiveFiles="31"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${uppercase:${level}}|${logger}|${aspnet-traceidentifier}|${aspnet-request-method}|${aspnet-request-url}|${message} ${exception:format=tostring}" />

    <!-- Errors only — quick scan during incidents -->
    <target xsi:type="File"
            name="errorFile"
            fileName="${logDirectory}/errors-${shortdate}.log"
            archiveFileName="${logDirectory}/archive/errors-{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            maxArchiveFiles="60"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8"
            layout="${longdate}|${uppercase:${level}}|${logger}|${aspnet-traceidentifier}|${message} ${exception:format=tostring}${newline}${exception:format=@}" />

    <target xsi:type="Console"
            name="console"
            layout="${longdate}|${uppercase:${level}}|${logger}|${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- Specific framework types first (final stops duplicate routing to broader Microsoft.* rules). -->
    <logger name="Microsoft.Hosting.Lifetime" minlevel="Info" writeTo="console,allFile" final="true" />
    <logger name="Microsoft.EntityFrameworkCore.Database.Command" minlevel="Warn" writeTo="console,allFile" final="true" />

    <logger name="Microsoft.*" minlevel="Warn" writeTo="console,allFile" />
    <logger name="System.Net.Http.*" minlevel="Warn" writeTo="console,allFile" />

    <!-- Application + libraries (your namespaces typically start here) -->
    <logger name="*" minlevel="Info" writeTo="console,allFile" />

    <!-- Errors also land in errors-*.log for quick production triage -->
    <logger name="*" minlevel="Error" writeTo="errorFile" />
  </rules>
</nlog>
